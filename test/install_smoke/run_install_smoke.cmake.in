set(prefix "@CMAKE_CURRENT_BINARY_DIR@/install-smoke-prefix")
set(build_dir "@CMAKE_CURRENT_BINARY_DIR@/install-smoke-build")
set(source_dir "@CMAKE_CURRENT_SOURCE_DIR@/test/install_smoke")

file(REMOVE_RECURSE "${prefix}" "${build_dir}")

execute_process(
  COMMAND "@CMAKE_COMMAND@" --install "@CMAKE_CURRENT_BINARY_DIR@" --prefix "${prefix}"
  RESULT_VARIABLE install_result
)
if(NOT install_result EQUAL 0)
  message(FATAL_ERROR "miniflex install smoke test: install step failed")
endif()

execute_process(
  COMMAND "@CMAKE_COMMAND@" -S "${source_dir}" -B "${build_dir}" -DCMAKE_PREFIX_PATH=${prefix}
  RESULT_VARIABLE configure_result
)
if(NOT configure_result EQUAL 0)
  message(FATAL_ERROR "miniflex install smoke test: configure step failed")
endif()

execute_process(
  COMMAND "@CMAKE_COMMAND@" --build "${build_dir}"
  RESULT_VARIABLE build_result
)
if(NOT build_result EQUAL 0)
  message(FATAL_ERROR "miniflex install smoke test: build step failed")
endif()

execute_process(
  COMMAND "${build_dir}/miniflex_install_smoke"
  RESULT_VARIABLE run_result
)
if(NOT run_result EQUAL 0)
  message(FATAL_ERROR "miniflex install smoke test: executable failed")
endif()
